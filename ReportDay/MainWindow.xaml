<Window 
    Icon="/favicon.ico"
    x:Class="ReportDay.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Генератор отчетов" Height="600" Width="500" Background="#F5F5F5">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <ComboBox x:Name="GreetingCombo" Margin="0,0,0,20" SelectedIndex="0">
                    <ComboBoxItem Content="Добрый день"/>
                    <ComboBoxItem Content="Добрый вечер"/>
                    <ComboBoxItem Content="Доброе утро"/>
                </ComboBox>

                <TextBlock Text="1. Задачи" FontWeight="Bold" FontSize="16"/>
                <ItemsControl ItemsSource="{Binding Tasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <StackPanel>
                                    <TextBox Text="{Binding Title}" Width="300" KeyDown="OnKeyDown" Tag="Название задачи..."/>
                                    <TextBox Text="{Binding Link}" Width="300" Margin="0,2,0,0" KeyDown="OnKeyDown" Foreground="Blue"/>
                                </StackPanel>
                                <Button Content="-" Click="RemoveTask_Click" Width="20" Height="20" Margin="5,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="+ Добавить задачу" Click="AddTask_Click" HorizontalAlignment="Left" Margin="30,5,0,20"/>

                <TextBlock Text="2. Пофикшено" FontWeight="Bold" FontSize="16" Margin="0,10,0,0"/>
                <ItemsControl ItemsSource="{Binding Fixed}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <StackPanel>
                                    <TextBox Text="{Binding Title}" Width="300" KeyDown="OnKeyDown"/>
                                    <TextBox Text="{Binding Link}" Width="300" Margin="0,2,0,0" KeyDown="OnKeyDown" Foreground="Blue"/>
                                </StackPanel>
                                <Button Content="-" Click="RemoveTask_Click" Width="20" Height="20" Margin="5,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="+ Добавить" Click="AddFixed_Click" HorizontalAlignment="Left" Margin="30,5,0,20"/>

                <TextBlock Text="3. Вернул в работу" FontWeight="Bold" FontSize="16" Margin="0,10,0,0"/>
                <ItemsControl ItemsSource="{Binding Returned}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <StackPanel>
                                    <TextBox Text="{Binding Title}" Width="300" KeyDown="OnKeyDown"/>
                                    <TextBox Text="{Binding Link}" Width="300" Margin="0,2,0,0" KeyDown="OnKeyDown" Foreground="Blue"/>
                                    <TextBox Text="{Binding Reason}" Width="300" Margin="0,2,0,0" KeyDown="OnKeyDown" FontStyle="Italic" Tag="Причина..."/>
                                </StackPanel>
                                <Button Content="-" Click="RemoveTask_Click" Width="20" Height="20" Margin="5,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="+ Добавить" Click="AddReturned_Click" HorizontalAlignment="Left" Margin="30,5,0,20"/>

                <Button Content="СКОПИРОВАТЬ ОТЧЕТ" 
                        Height="45" 
                        Background="#4CAF50" 
                        Foreground="White" 
                        FontWeight="Bold" 
                        Click="CopyReport_Click" 
                        Margin="0,20,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <Canvas x:Name="FireworksCanvas" IsHitTestVisible="False"/>
    </Grid>
</Window>